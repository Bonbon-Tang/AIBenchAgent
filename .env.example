# 环境变量配置
# 复制此文件为 .env 并填入实际值

# ======== LLM 供应商配置 ========

# 使用本地模型（设置为任意非空值启用）
# USE_LOCAL_MODEL=1
# LOCAL_API_BASE=http://localhost:30000/v1
# LOCAL_API_KEY=your-local-api-key

# Boyue 服务器
# BOYUE_API_KEY=your-boyue-api-key

# DeepSeek API
# DEEPSEEK_API_KEY=your-deepseek-api-key

# Google Gemini API
# GEMINI_API_KEY=your-gemini-api-key

# Anthropic Claude（默认从 ANTHROPIC_API_KEY 环境变量读取）
# ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI（默认从 OPENAI_API_KEY 环境变量读取）
# OPENAI_API_KEY=your-openai-api-key
