          "FLASHINFER_DISABLE_VERSION_CHECK": "1"
        },
        "serve_command": "vllm serve /mnt/nvme1n1/ml_research/models_4/qwen3-0.6b-local --host 0.0.0.0 --port 18080 --dtype bfloat16 --tensor-parallel-size 1 --max-model-len 1024 --gpu-memory-utilization 0.3"
